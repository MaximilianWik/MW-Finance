# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Get from https://neon.tech → your project → Connection string (pooled)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/mwfinance?sslmode=require"

# ─── Enable Banking ─────────────────────────────────────────────────────────
# Application ID (used as the JWT `kid`). From the Enable Banking control panel.
ENABLE_BANKING_APP_ID="cf589be3-3755-465b-a8df-a90a16a31403"
# RSA private key, PEM, base64-encoded (single line — avoids newline breakage in env vars).
# Generate: base64 -w0 YOUR-APP-ID.pem   (macOS: base64 -i YOUR-APP-ID.pem)
ENABLE_BANKING_PRIVATE_KEY_BASE64="LS0tLS1CRUdJTiBQUklWQVRF..."
# Redirect URL registered in the Enable Banking panel — must match exactly.
ENABLE_BANKING_REDIRECT_URL="http://localhost:3000/api/callback"
# ASPSP (bank) to connect. Use Enable Banking's canonical name + ISO country.
ENABLE_BANKING_ASPSP_NAME="Nordea"
ENABLE_BANKING_ASPSP_COUNTRY="SE"
# PSU type: personal | business
ENABLE_BANKING_PSU_TYPE="personal"
# Consent validity in days (max ~90, bank-dependent).
ENABLE_BANKING_CONSENT_DAYS="90"

# ─── Gemini (categorization fallback) ───────────────────────────────────────
# https://aistudio.google.com/apikey  (free tier)
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.0-flash"

# ─── Notifications (ntfy) ───────────────────────────────────────────────────
NTFY_SERVER="https://ntfy.sh"
# Pick an unguessable topic; subscribe to it in the ntfy app on your phone.
NTFY_TOPIC="mwfinance-2f8a1c9d"

# ─── Cron / sync protection ─────────────────────────────────────────────────
# Random secret. Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="change-me-to-a-long-random-string"

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
